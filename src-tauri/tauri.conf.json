{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kyro IDE",
  "version": "1.0.0",
  "identifier": "com.kyroide.app",
  "build": {
    "beforeBuildCommand": "bun run build",
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../.next"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kyro IDE",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "visible": true,
        "focus": true,
        "url": "http://localhost:3000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "MIT License",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "Kyro IDE is a free, open-source, privacy-first AI-powered development environment that delivers premium IDE features without the premium price tag.",
    "shortDescription": "AI-Powered Privacy-First IDE",
    "targets": "all",
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "installMode": "currentUser"
      },
      "wix": {
        "language": "en-US"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libssl3", "libayatana-appindicator3-1"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "externalBin": []
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "git",
          "cmd": "git",
          "args": true
        },
        {
          "name": "node",
          "cmd": "node",
          "args": true
        },
        {
          "name": "bun",
          "cmd": "bun",
          "args": true
        },
        {
          "name": "python",
          "cmd": "python3",
          "args": true
        }
      ]
    },
    "updater": {
      "active": false
    }
  }
}
